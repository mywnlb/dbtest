flowchart TB
  subgraph Prepare["PREPARE"]
    P1["Receive SQL text"]
    P2["Parse or load ParsedStatementTemplate"]
    P3["Bind names and infer ParameterMetadata"]
    P4["Optimize optional template"]
    P5["Publish PreparedStatementHandle in session registry"]
  end

  subgraph Execute["EXECUTE"]
    E1["Lookup handle"]
    E2["Validate state and schema/statistics versions"]
    E3{"stale?"}
    E4["Reprepare: rebind and reoptimize"]
    E5["Bind ParameterBindingSet"]
    E6["Acquire PlanUseGuard"]
    E7["Execute through SQL Executor"]
    E8["Release guard"]
  end

  subgraph Deallocate["DEALLOCATE"]
    D1["Lookup handle"]
    D2["Mark DEALLOCATING"]
    D3{"refCount == 0?"}
    D4["Retire templates and remove registry entry"]
    D5["Wait or defer cleanup"]
  end

  P1 --> P2 --> P3 --> P4 --> P5
  E1 --> E2 --> E3
  E3 -->|"yes"| E4 --> E5
  E3 -->|"no"| E5
  E5 --> E6 --> E7 --> E8
  D1 --> D2 --> D3
  D3 -->|"yes"| D4
  D3 -->|"no"| D5 --> D4
