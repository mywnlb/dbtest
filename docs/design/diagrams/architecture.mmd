  Alloc --> InodeRepo
  Alloc --> ExtPolicy
  Alloc --> BufferPool
  Reserve --> SpaceRepo

  BufferPool --> Frame
  Frame --> Latch
  BufferPool --> PageStore
  BufferPool --> Dirty

  SpaceRepo --> BufferPool
  XdesRepo --> BufferPool
  InodeRepo --> BufferPool

  PageStore --> Registry
  PageStore --> DataFile
  DataFile --> AutoExtend
  DataFile --> Storage

  FlushCoord --> Dirty
  FlushCoord --> Doublewrite
