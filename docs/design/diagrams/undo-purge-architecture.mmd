    SavepointApi["SavepointService"]
  end

  subgraph UndoCore["storage.trx.undo.core"]
    UndoCtx["UndoContext"]
    UndoState["UndoLogStateMachine"]
    RsegDir["RollbackSegmentDirectory"]
    SlotMgr["RollbackSegmentSlotManager"]
  end

  subgraph UndoStorage["storage.trx.undo.storage"]
    UtsRepo["UndoTablespaceRepository"]
    Rseg["RollbackSegment"]
    USeg["UndoSegment"]
    UPage["UndoPage"]
    URec["UndoRecord"]
  end

  subgraph HistoryPkg["storage.trx.undo.history"]
    History["HistoryList"]
    HistoryCursor["HistoryCursor"]
    PurgeBoundary["PurgeBoundary"]
  end

  subgraph PurgePkg["storage.trx.purge"]
    PurgeCoord["PurgeCoordinator"]
    PurgeView["PurgeViewProvider"]
    PurgeWorker["PurgeWorker"]
    Truncation["UndoTruncationService"]
  end

  subgraph RecoveryPkg["storage.trx.undo.recovery"]
    UndoRecovery["UndoRecoveryService"]
    RsegScanner["RollbackSegmentScanner"]
  end

  subgraph Storage["已有存储模块"]
    MTR["MiniTransaction"]
    BufferPool["BufferPool"]
    Disk["DiskSpaceManager / FSP"]
    Redo["RedoLogManager"]
    LockMgr["LockManager"]
    ReadViewMgr["ReadViewManager"]
    Dictionary["DataDictionary"]
  end

