flowchart TB
  subgraph Upper["上层存储引擎"]
    BTree["B+Tree / Index Manager"]
    Record["Record Manager"]
    DDL["DDL / Data Dictionary Gateway"]
  end

  subgraph Api["storage.api"]
    DSM["DiskSpaceManager\nFacade"]
    PCM["PageCursorFactory"]
  end

  subgraph Mtr["storage.mtr"]
    MTM["MiniTransactionManager"]
    MTR["MiniTransaction\nUnit of Work"]
    Memo["MtrMemoStack"]
    RedoCollector["RedoRecordCollector"]
  end

  subgraph Fsp["storage.fsp"]
    Alloc["SegmentPageAllocator"]
    Reserve["SpaceReservationService"]
    SpaceRepo["SpaceHeaderRepository"]
    XdesRepo["ExtentDescriptorRepository"]
    InodeRepo["SegmentInodeRepository"]
    ExtPolicy["ExtentAllocationPolicy"]
  end

  subgraph Buf["storage.buf"]
    BufferPool["BufferPool"]
    Frame["BufferFrame"]
    Latch["PageLatch"]
    Dirty["DirtyPageQueue"]
  end

  subgraph Fil["storage.fil"]
    Registry["TablespaceRegistry"]
    PageStore["PageStore"]
    AutoExtend["AutoExtendPolicy"]
    DataFile["DataFileGateway"]
  end

  subgraph Redo["storage.redo"]
    RedoWriter["RedoLogWriter"]
    Lsn["LsnAllocator"]
    Checkpoint["CheckpointCoordinator"]
  end

  subgraph Flush["storage.flush"]
    FlushCoord["FlushCoordinator"]
    Doublewrite["DoublewriteStrategy"]
  end

  subgraph Recovery["storage.recovery"]
    RecoverySvc["RecoveryService"]
    RedoApplier["RedoRecordApplier"]
  end

  Storage["File System\n.ibd / undo / temp / redo / doublewrite"]

  BTree --> DSM
  Record --> PCM
  DDL --> DSM

  DSM --> MTM
