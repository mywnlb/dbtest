    sortLimit["Apply ORDER BY / LIMIT if needed"]
    returnRows["Return ResultSet"]
    close["Close cursor, release statement resources"]

    start --> parse --> bind --> mdl --> trx --> plan --> open --> access --> readType
    readType --> consistent
    readType --> locking
    consistent --> filter
    locking --> filter
    filter --> project --> sortLimit --> returnRows --> close

    locking --> releasePage["Storage layer releases page latch before row-lock wait"]
